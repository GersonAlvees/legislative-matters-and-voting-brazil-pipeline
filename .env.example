# Configuração da Ingestão

# Destino de armazenamento: "local" ou "s3"
STORAGE_SOURCE=local

# Caminho local da camada bronze (usado quando STORAGE_SOURCE=local)
BRONZE_PATH=bronze

# Bucket S3 (usado quando STORAGE_SOURCE=s3)
S3_BUCKET_NAME=legislative-matters-and-voting-brazil-pipeline

# URL base da API do Senado
SENADO_API_BASE_URL=https://legis.senado.leg.br/dadosabertos

# Ano padrão para ingestão de matérias e votos
INGESTION_YEAR=2025

# Timeout das requisições HTTP (segundos)
API_REQUEST_TIMEOUT=30

# Pausa entre requisições sequenciais na ingestão de votos (segundos)
API_RETRY_PAUSE=0.3
